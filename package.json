{
  "name": "cue-crew",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.15.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11.10.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24 <25",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.10.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "screenshot": "node scripts/capture-screenshot.mjs",
    "screenshot:prep": "node scripts/capture-screenshot.mjs --preset=prep-panel --outDir=tmp/screenshots/prep-panel",
    "screenshot:response": "node scripts/capture-screenshot.mjs --preset=response-panel --outDir=tmp/screenshots/response-panel",
    "screenshot:result": "node scripts/capture-screenshot.mjs --preset=result-panel --outDir=tmp/screenshots/result-panel",
    "screenshot:ui": "node scripts/capture-screenshot.mjs --preset=ui-critical --outDir=tmp/screenshots/ui-critical",
    "verify:ui": "npm run build && npm run screenshot:ui",
    "verify": "npm audit signatures && npm run build",
    "cf:preview": "npm run build && wrangler pages dev dist --compatibility-date=2026-05-30",
    "cf:deploy": "npm run build && wrangler pages deploy dist --project-name=cue-crew"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "wrangler": "4.94.0"
  }
}
